### Build Arguments (override via "--build-arg")
ARG GOVER="1.26"
ARG ALPINE="3.22"

################################################################################
### Stage #1:  Alpine-based Go dev env with Conduit built & installed
################################################################################
FROM docker.io/library/golang:${GOVER}-alpine AS conduit-fta-build
LABEL maintainer="Kevin Pelzel <kpelzel@lanl.gov>"

ARG TARGETARCH
ARG TARGETOS

ARG GOARCH="${TARGETARCH}"
ARG GOOS="${TARGETOS}"
WORKDIR "/conduit"
RUN mkdir -p /conduit 

RUN apk add --no-cache \
        git

# Copy go.mod and go.sum first for better layer caching
COPY go.mod go.sum ./
RUN go mod download \
    && go install golang.org/x/tools/go/analysis/passes/nilness/cmd/nilness@latest

# Copy the rest of the source code
COPY . .

# run tests
RUN go vet -vettool $(which nilness) ./... \
    && go test ./...

# build conduit-fta
RUN --mount=type=cache,target=/root/.cache/go-build \
    go build -o conduit-fta ./cmd/fta \
    && cp -v conduit-fta /sbin/conduit-fta

ENTRYPOINT [ "/sbin/conduit-fta" ]
CMD [ "-h" ]


################################################################################
### Stage #2:  Pure Alpine container (no Go) with Kraken/Layercake copied in
###
### This container is intended to provide a runnable kraken-layercake environment.
### You will likely want ot pass in /config.yaml /state.json and various /tftp/** files.
### E.g. podman run --net=host -v tftp:/tftp -v etc/kraken:/etc/kraken kraken-layercake
###
################################################################################
FROM docker.io/library/alpine:${ALPINE} AS conduit-fta
LABEL maintainer="Kevin Pelzel <kpelzel@lanl.gov>"

COPY --from=conduit-fta-build /sbin/conduit-fta /sbin/conduit-fta


# add dependencies
RUN apk add \
        bash \
    && mkdir -p /etc/conduit 

ENTRYPOINT [ "/sbin/conduit-fta" ]
# CMD [ "--config", "/etc/conduit/config.yaml" ]
