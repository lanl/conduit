version: 1

dn: olcDatabase={1}mdb,cn=config
changetype: modify
replace: olcAccess
olcAccess: {0}to dn.base="" by * read
olcAccess: {1}to attrs=userPassword by dn.exact="uid=admin,dc=example,dc=com" write by self write by anonymous auth by * none
olcAccess: {2}to * by dn.exact="uid=admin,dc=example,dc=com" write by anonymous read by users read by * none